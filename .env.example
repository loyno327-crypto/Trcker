# Telegram
BOT_TOKEN=123456:AAExampleTokenReplaceMe
WEBAPP_URL=https://your-domain.example.com

# Database
DATABASE_URL=sqlite+aiosqlite:///./habit_tracker.db

# Web server (FastAPI, serves the WebApp + API for the bot)
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Некоторые хостинги ботов (например, BotHost) сами задают порт через
# переменную окружения PORT — если она есть в окружении, main.py использует
# её вместо WEB_PORT, ничего вручную настраивать не нужно.

# Scheduler
REMINDER_CHECK_INTERVAL_SECONDS=60

# Logging
LOG_LEVEL=INFO
